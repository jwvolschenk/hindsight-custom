{
    "name": "hindsight-custom-opencode",
    "version": "1.0.0",
    "description": "Project-aware long-term memory for OpenCode via Hindsight",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts",
        "dev": "tsc --watch"
    },
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.0.0"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.3.13",
        "@types/node": "^22.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.7.0"
    },
    "engines": {
        "node": ">=22"
    }
}
